<?xml version="1.0"?>
<ruleset name="Real3D Flipbook">
	<description>WordPress Coding Standards for Real3D Flipbook plugin.</description>

	<rule ref="WordPress"/>

	<rule ref="WordPress.NamingConventions.ValidVariableName">
		<exclude name="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase"/>
		<exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
		<exclude name="WordPress.NamingConventions.ValidVariableName.PropertyNotSnakeCase"/>
	</rule>
	<rule ref="WordPress.NamingConventions.ValidFunctionName">
		<exclude name="WordPress.NamingConventions.ValidFunctionName.MethodNameInvalid"/>
		<exclude name="WordPress.NamingConventions.ValidFunctionName.FunctionNameInvalid"/>
	</rule>
	<rule ref="WordPress.PHP.YodaConditions">
		<exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
	</rule>
	<rule ref="Universal.Operators.StrictComparisons">
		<exclude name="Universal.Operators.StrictComparisons.LooseEqual"/>
		<exclude name="Universal.Operators.StrictComparisons.LooseNotEqual"/>
	</rule>
	<rule ref="Squiz.Commenting.FunctionComment">
		<exclude name="Squiz.Commenting.FunctionComment.Missing"/>
		<exclude name="Squiz.Commenting.FunctionComment.WrongStyle"/>
	</rule>
	<rule ref="Squiz.Commenting.VariableComment">
		<exclude name="Squiz.Commenting.VariableComment.Missing"/>
	</rule>
	<rule ref="Squiz.Commenting.InlineComment">
		<exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
	</rule>
	<rule ref="Squiz.Commenting.FileComment">
		<exclude name="Squiz.Commenting.FileComment.Missing"/>
		<exclude name="Squiz.Commenting.FileComment.WrongStyle"/>
	</rule>
	<rule ref="Squiz.Commenting.ClassComment">
		<exclude name="Squiz.Commenting.ClassComment.Missing"/>
	</rule>
	<rule ref="WordPress.Files.FileName">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
	</rule>
	<rule ref="WordPress.PHP.StrictInArray">
		<exclude name="WordPress.PHP.StrictInArray.MissingTrueStrict"/>
	</rule>
	<rule ref="Generic.CodeAnalysis.UnusedFunctionParameter">
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter.FoundAfterLastUsed"/>
	</rule>
	<rule ref="Squiz.PHP.CommentedOutCode">
		<exclude name="Squiz.PHP.CommentedOutCode.Found"/>
	</rule>
	<rule ref="Universal.Arrays.DuplicateArrayKey">
		<exclude name="Universal.Arrays.DuplicateArrayKey.Found"/>
	</rule>
	<rule ref="Universal.Files.SeparateFunctionsFromOO">
		<exclude name="Universal.Files.SeparateFunctionsFromOO.Mixed"/>
	</rule>
	<rule ref="WordPress.WP.EnqueuedResourceParameters">
		<exclude name="WordPress.WP.EnqueuedResourceParameters.MissingVersion"/>
		<exclude name="WordPress.WP.EnqueuedResourceParameters.NotInFooter"/>
	</rule>
	<rule ref="WordPress.DB.DirectDatabaseQuery">
		<exclude name="WordPress.DB.DirectDatabaseQuery.DirectQuery"/>
	</rule>
	<rule ref="WordPress.DB.SlowDBQuery">
		<exclude name="WordPress.DB.SlowDBQuery.slow_db_query_tax_query"/>
	</rule>
	<rule ref="Squiz.PHP.DisallowSizeFunctionsInLoops">
		<exclude name="Squiz.PHP.DisallowSizeFunctionsInLoops.Found"/>
	</rule>
	<rule ref="Generic.CodeAnalysis.ForLoopWithTestFunctionCall">
		<exclude name="Generic.CodeAnalysis.ForLoopWithTestFunctionCall.NotAllowed"/>
	</rule>

	<arg name="extensions" value="php"/>
	<file>.</file>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/lib/*</exclude-pattern>
</ruleset>
